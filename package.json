{
  "name": "bedones-agents",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:design": "pnpm --filter design dev",
    "dev:whatsapp-connector": "pnpm --filter whatsapp-connector start:dev",
    "build": "pnpm -r build",
    "build:whatsapp-connector": "pnpm --filter whatsapp-connector build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "ajv@<8.18.0": ">=8.18.0",
      "brace-expansion@<5.0.6": ">=5.0.6",
      "dompurify@<3.4.11": ">=3.4.11",
      "esbuild@<0.28.1": ">=0.28.1",
      "fast-uri@<3.1.2": ">=3.1.2",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "form-data@<4.0.6": ">=4.0.6",
      "hono@<4.12.25": ">=4.12.25",
      "js-yaml@<4.2.0": ">=4.2.0",
      "langsmith@<0.6.0": ">=0.6.0",
      "lodash@<4.18.0": ">=4.18.0",
      "multer@<2.2.0": ">=2.2.0",
      "path-to-regexp@<8.4.0": ">=8.4.0",
      "picomatch@<4.0.4": ">=4.0.4",
      "postcss@<8.5.10": ">=8.5.10",
      "protobufjs@<7.6.3": ">=7.6.3",
      "qs@<6.15.2": ">=6.15.2",
      "tar@<7.5.16": ">=7.5.16",
      "undici@<7.28.0": ">=7.28.0",
      "uuid@<13.0.1": ">=13.0.1",
      "ws@<8.21.0": ">=8.21.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  }
}
