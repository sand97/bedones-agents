{
  "name": "design",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3008",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview --port 3008",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
  }
}
