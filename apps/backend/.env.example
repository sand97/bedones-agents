SERVER_PORT=3005

META_SYSTEM_USER=****
# used to send message as Bedones
CORE_WHATSAPP_NUMBER_ID=104138399136545
TEMPLATE_INVITE_ID=verification_code
# OTP template used by the WhatsApp login flow (POST /auth/whatsapp/send-otp).
# Defaults to TEMPLATE_INVITE_ID if not set — for now we reuse the same template.
TEMPLATE_LOGIN_ID=verification_code

# WhatsApp opt-in (notifications to org members)
# Approved Meta template with a Quick Reply Yes/No button + two body variables
# ({{firstname}}, {{company}}). Members tap "Yes" to open their rolling 24h
# customer-service window. The template is sent on two triggers:
#   (a) the morning the member's org-local hour hits LOCAL_HOUR (daily cron),
#   (b) right after they enable a notification in the dashboard.
# When the member then messages the CORE number their window (re)opens and we
# send a confirmation with a CTA button deep-linking to their notification
# settings (FRONTEND_URL/app/<orgId>/members?notif=1) — no second opt-in asked.
# Language is taken per-user from User.locale (fr|en); the daily send hour uses
# the per-org Organisation.timezone — so there is no global LANG/TZ env here.
WHATSAPP_OPTIN_TEMPLATE_NAME=daily_optin
# Cron for the hourly tick that scans orgs whose local time just hit LOCAL_HOUR.
WHATSAPP_OPTIN_TICK_CRON=0 * * * *
# Org-local hour (0-23) at which eligible members get the daily template.
WHATSAPP_OPTIN_LOCAL_HOUR=8

# Facebook App Configuration (to be filled with actual values)
FACEBOOK_APP_ID=4075904832690760
FACEBOOK_APP_SECRET=***
FACEBOOK_WEBHOOK_VERIFY_TOKEN=***

# Instagram setup
INSTAGRAM_APP_ID=1336655694790025
INSTAGRAM_APP_SECRET=***
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=***

# TikTok
TIKTOK_CLIENT_KEY=***
TIKTOK_CLIENT_SECRET=***

# WhatsApp Webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=***
MIGRATION_TOKEN=***

# WhatsApp Catalog Connector — the in-repo wppconnect service (apps/whatsapp-connector)
# used to read the public catalogue of a WhatsApp number for the Commerce Manager
# migration. We inject a page script through its generic /whatsapp/execute-script.
WHATSAPP_CATALOG_CONNECTOR_URL=http://localhost:3001
# Sent as `x-bedones-target-instance` — must match the connector's CONNECTOR_INSTANCE_ID
# (leave empty if the connector doesn't enforce an instance id).
WHATSAPP_CONNECTOR_INSTANCE_ID=
# Base URL of THIS backend, reachable from the connector — the injected script
# calls it back to upload images and save the catalogue. Defaults to APP_URL.
WHATSAPP_MIGRATION_CALLBACK_URL=http://localhost:3005
# Whatsapp seed
SEED_WHATSAPP_PHONE_NUMBER_ID=1003867186133830
SEED_WHATSAPP_TOKEN=***
SEED_WHATSAPP_CATALOG_ID=2398583830601212

# Database
DATABASE_URL=postgresql://bedones:bedones@localhost:5255/bedones

# Redis
REDIS_URL=redis://localhost:6379

# Message history sync — rolling window (in days) backfilled on account connect.
# Runs progressively in the background. Default 30, bounded to 1..180.
# Provider caps still apply (WhatsApp ~6 months, TikTok 90d, Messenger/IG ~20 msgs/thread).
MESSAGE_HISTORY_SYNC_WINDOW_DAYS=30

# Auth
JWT_SECRET=***
SESSION_SECRET=***

# ─── Paiement / Souscription (Stripe) ──────────────────────────────────────────
# Système de souscription récurrente (forfaits Pro/Business) + achat ponctuel de
# crédits supplémentaires. Voir apps/backend/src/payment.
#
# Deux environnements Stripe distincts (production + sandbox), chacun avec ses
# clés et son secret webhook. STRIPE_MODE choisit l'environnement ACTIF pour les
# paiements sortants (création de checkouts). Les webhooks, eux, sont routés par
# endpoint et vérifiés avec le secret de leur mode :
#   - production : POST /payment/webhook/stripe
#   - sandbox    : POST /payment/webhook/stripe-sandbox
# Valeurs: sandbox | production. Défaut / fallback = production.
STRIPE_MODE=production

# Production
# Clé secrète Stripe (sk_live_...). Laisser vide désactive les paiements en prod.
STRIPE_SECRET_KEY=sk_live_***
# Secret de signature du webhook production (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_***

# Sandbox (tests). Utilisé quand STRIPE_MODE=sandbox et par l'endpoint
# /payment/webhook/stripe-sandbox.
STRIPE_SANDBOX_SECRET_KEY=sk_test_***
STRIPE_SANDBOX_WEBHOOK_SECRET=whsec_***

# ─── Paiement mobile money (NotchPay) ──────────────────────────────────────────
# Mobile money (Orange Money / MTN MoMo) via NotchPay. Paiement PONCTUEL : la
# souscription mobile donne un accès à durée fixe (pas de renouvellement auto),
# un cron la fait expirer à l'échéance. Webhook: POST /payment/webhook/notchpay.
# Clé publique NotchPay (envoyée en header Authorization). Vide = mobile money off.
NOTCHPAY_PUBLIC_KEY=***
# Clé de hash pour vérifier la signature des webhooks (header x-notch-signature).
NOTCHPAY_HASH=***
# Base URL de l'API NotchPay (défaut: https://api.notchpay.co).
NOTCHPAY_BASE_URL=https://api.notchpay.co
# Devise de facturation mobile money (défaut: XAF) + taux de conversion depuis
# l'USD (prix de référence des forfaits). À ajuster/automatiser selon le taux réel.
NOTCHPAY_CURRENCY=XAF
NOTCHPAY_USD_RATE=600
# Cron d'expiration des accès non renouvelés (défaut: tous les jours à 03:00 UTC).
# Ce tick envoie aussi les rappels d'échéance (mobile money) avant expiration.
PAYMENT_EXPIRY_CRON=0 3 * * *

# ─── Notifications WhatsApp d'abonnement ───────────────────────────────────────
# Envoyées depuis le numéro CORE (CORE_WHATSAPP_NUMBER_ID + META_SYSTEM_USER, déjà
# définis plus haut) via des templates Meta approuvés. Noms surchargeables :
#   A. Rappel d'échéance (mobile money)     → payment_due_reminder
#   B. Enquête de départ (WhatsApp Flow)    → feedback_survey_form_1
#   C. Fin pour échec de paiement           → payment_failed_4
WHATSAPP_TPL_PAYMENT_DUE=payment_due_reminder
WHATSAPP_TPL_PAYMENT_FAILED=payment_failed_4
WHATSAPP_TPL_CHURN_SURVEY=feedback_survey_form_1
# Code langue des templates (défaut: fr).
WHATSAPP_TPL_LANG=fr
# Nombre de jours avant l'échéance pour envoyer le rappel mobile (défaut: 3).
PAYMENT_REMINDER_DAYS_BEFORE=3

# ─── Factures PDF ──────────────────────────────────────────────────────────────
# Générées via pdfmake (GET /payment/org/:id/payments/:paymentId/invoice).
# Coordonnées de l'émetteur sur la facture (valeurs par défaut sinon) :
INVOICE_SELLER_NAME=Bedones
INVOICE_SELLER_ADDRESS=Akwa, Douala, Cameroun
INVOICE_SELLER_EMAIL=contact@bedones.com
INVOICE_SELLER_PHONE=+237 6 90 07 28 84
INVOICE_SELLER_TAX_ID=P049818395574U

# URLs
APP_URL=https://api-moderator.bedones.local
FRONTEND_URL=https://moderator.bedones.local
# Origines autorisées par le CORS HTTP, séparées par des virgules
# (frontend moderator + studio design, etc.)
CORS_URLS=https://moderator.bedones.local,https://design.bedones.local

# ─── MCP (Model Context Protocol) connector ───
# Public base URL of the MCP server (OAuth issuer + discovery metadata).
# Usually equals APP_URL. Clients add "<MCP_PUBLIC_URL>/mcp" as a connector.
MCP_PUBLIC_URL=https://api-moderator.bedones.test
# Secret used to sign MCP access tokens (keep distinct from JWT_SECRET).
# Falls back to SESSION_SECRET if unset.
MCP_JWT_SECRET=***
# Access token TTL (seconds, default 3600) and refresh TTL (default 30 days).
MCP_OAUTH_TOKEN_TTL=3600
MCP_OAUTH_REFRESH_TTL=2592000
# ChatGPT Apps SDK domain verification: paste the token shown in the app's
# "Domain verification" step. Served verbatim at
# /.well-known/openai-apps-challenge. Rotatable — just change this value.
OPENAI_APPS_CHALLENGE_TOKEN=

# ─── Debug MCP (internal, OFF by default) ───
# A SECOND, isolated MCP server at /debug-mcp, separate from the production /mcp.
# Auth reuses the production OAuth (so Claude / ChatGPT connectors can drive it)
# but is LOCKED to ONE organisation: a token issued for any other org is
# rejected. Tools: chat_with_agent (dry-run the live agent + full trace),
# list_tables/read_table/list_products (org-scoped reads, masked), qdrant_*,
# add_products/index_products. Enable consciously.
DEBUG_MCP_ENABLED=false
# The single organisation the debug MCP is allowed to touch. Connect via OAuth
# and pick THIS organisation on the consent screen.
DEBUG_MCP_ORG_ID=
# OPTIONAL static bearer for non-OAuth clients (CLI / Codex). Leave empty for
# OAuth-only; when set, clients may send Authorization: Bearer <token>.
DEBUG_MCP_TOKEN=

# Minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=***
MINIO_SECRET_KEY=***
MINIO_BUCKET=bedones-uploads

NODE_ENV=development

# ─── AI Models ────────────────────────────────────────────────────────────────
# Strategy: a primary provider with the others as automatic fallback, every LLM call.
# Default primary is Gemini; switch the whole platform (live agent included) with:
#   LLM_DEFAULT_PROVIDER=openai   → ChatGPT primary
#   LLM_DEFAULT_PROVIDER=xiaomi   → Xiaomi MiMo primary (cheapest, see pricing)
# The two non-primary providers become fallbacks (only those with a key set).
LLM_DEFAULT_PROVIDER=gemini
# Per-use-case override (each defaults to LLM_DEFAULT_PROVIDER). Lets the agent
# configuration (onboarding/context analysis, the THINKING model) and the live
# customer replies (the FLASH/PRO/ULTRA models) run on different providers — e.g.
# keep Gemini for config but answer customers on the much cheaper Xiaomi MiMo:
#   LLM_PROVIDER_THINKING=gemini   (agent configuration)
#   LLM_PROVIDER_LIVE=xiaomi       (message responses)
# LLM_PROVIDER_THINKING=
# LLM_PROVIDER_LIVE=
# Two tiers:
#   - THINKING: flagship reasoning model with extended thinking enabled.
#     Used for agent context processing (onboarding, catalog analysis,
#     knowledge ingestion).
#   - FLASH: lightweight/fast model. Used for live response generation
#     (DM replies, comment auto-replies, moderation).

# API keys
GEMINI_API_KEY=AI***
OPENAI_API_KEY=sk-****
# Xiaomi MiMo (OpenAI-compatible API). Leave empty to disable. Key format sk-xxxxx,
# created at the MiMo API Open Platform. The default base URL is MiMo's OpenAI-
# compatible endpoint; override only if it changes.
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# Thinking tier (advanced + reasoning)
GEMINI_MODEL_THINKING=gemini-3.1-pro-preview
OPENAI_MODEL_THINKING=gpt-5
XIAOMI_MODEL_THINKING=mimo-v2.5-pro

# Flash tier (lightweight, fast)
GEMINI_MODEL_FLASH=gemini-3-flash-preview
OPENAI_MODEL_FLASH=gpt-5-mini
XIAOMI_MODEL_FLASH=mimo-v2.5

# Thinking config
# Gemini 2.5: -1 = dynamic (model decides), 0 = off. Honored on thinking tier only.
GEMINI_THINKING_BUDGET=-1
# OpenAI reasoning effort: minimal | low | medium | high
OPENAI_REASONING_EFFORT=medium

# Agent execution limits + embeddings
AGENT_EMBEDDING_MODEL=text-embedding-3-small
AGENT_MODEL_CALL_LIMIT=6

# Conversation history depth loaded into the live agent's context.
# Global default (40) + optional per-tier overrides (flash | pro | ultra) so a
# more capable offer can carry a longer memory window.
AGENT_HISTORY_LIMIT=40
# AGENT_HISTORY_LIMIT_FLASH=40
# AGENT_HISTORY_LIMIT_PRO=60
# AGENT_HISTORY_LIMIT_ULTRA=80

# Output-token ceiling for the live agent's reply, per tier. Without it the model
# falls back to its full window (~65k for gemini-3-flash) and a single runaway
# generation can bill tens of thousands of tokens for one turn (≈ $0.20 instead
# of ~$0.003). A customer reply is short; pro/ultra get more room because their
# thinking tokens count against the same budget. Global default + per-tier
# overrides (defaults flash: 2048, pro: 8192, ultra: 16384).
# AGENT_MAX_OUTPUT_TOKENS=
# AGENT_MAX_OUTPUT_TOKENS_FLASH=2048
# AGENT_MAX_OUTPUT_TOKENS_PRO=8192
# AGENT_MAX_OUTPUT_TOKENS_ULTRA=16384

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Image Processing
IMAGE_CROPPER_URL=http://localhost:8011
CLIP_IMAGE_MODEL=Xenova/clip-vit-base-patch16
# Score de la meilleure correspondance image au-dessus duquel l'agent confirme le
# produit IMPLICITEMENT (sans redemander au client) et fait avancer la vente.
# En dessous, il demande au client de confirmer. Défaut 0.85, plage ]0,1].
IMAGE_IMPLICIT_CONFIRM_CONFIDENCE=0.85

# ─── PostHog (analytics, backend logs, error & LLM observability) ──────────────
# Project API key — this is a PUBLIC, write-only key (the same one the frontend
# uses). It is safe to expose; it cannot read any data. Leave empty to disable
# PostHog entirely (no-op).
POSTHOG_PROJECT_TOKEN=phc_xxx
# Also the OTLP logs endpoint host: logs ship to $POSTHOG_HOST/i/v1/logs.
POSTHOG_HOST=https://us.i.posthog.com
# Forward info-level logs to PostHog → Logs too. warn/error (and exceptions) are
# always forwarded; info is off by default to keep log volume — and cost — down.
# Set to true to see the full per-conversation trace (webhook + agent info logs).
POSTHOG_CAPTURE_INFO_LOGS=false
# service.name shown in PostHog → Logs (defaults to "bedones-backend").
OTEL_SERVICE_NAME=bedones-backend
