  "info": {
    "title": "Bedones Agents API",
    "description": "API backend pour le CRM social Bedones",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "test@bedones.com"
          },
          "password": {
            "type": "string",
            "example": "test1234"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "StatusResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          }
        },
        "required": [
          "status"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "avatar": {
            "type": "object",
            "nullable": true
          },
          "authType": {
            "type": "string",
            "enum": [
              "PASSWORD",
              "FACEBOOK",
              "INSTAGRAM"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "avatar",
          "authType"
        ]
      },
      "SocialAccountDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "FACEBOOK",
              "INSTAGRAM",
              "WHATSAPP",
              "TIKTOK"
            ]
          },
          "pageName": {
            "type": "object",
            "nullable": true
          },
          "providerAccountId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "provider",
          "pageName",
          "providerAccountId"
        ]
      },
      "OrganisationSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "logoUrl": {
            "type": "object",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "OWNER",
              "ADMIN",
              "MEMBER"
            ]
          },
          "socialAccounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SocialAccountDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "logoUrl",
          "role",
          "socialAccounts"
        ]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDto"
          },
          "organisations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganisationSummaryDto"
            }
          }
        },
        "required": [
          "user",
          "organisations"
        ]
      },
      "CreateOrganisationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Mon entreprise"
          }
        },
        "required": [
          "name"
        ]
      },
      "OrgSocialAccountDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "FACEBOOK",
              "INSTAGRAM",
              "WHATSAPP",
              "TIKTOK"
            ]
          },
          "providerAccountId": {
            "type": "string"
          },
          "pageName": {
            "type": "object",
            "nullable": true
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "provider",
          "providerAccountId",
          "pageName",
          "scopes",
          "createdAt"
        ]
      },
      "OrgMemberUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "avatar": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "avatar"
        ]
      },
      "OrgMemberDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "OWNER",
              "ADMIN",
              "MEMBER"
            ]
          },
          "user": {
            "$ref": "#/components/schemas/OrgMemberUserDto"
          }
        },
        "required": [
          "id",
          "role",
          "user"
        ]
      },
      "OrganisationResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "logoUrl": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "socialAccounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrgSocialAccountDto"
            }
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrgMemberDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "logoUrl",
          "createdAt",
          "updatedAt",
          "socialAccounts",
          "members"
        ]
      },
      "UpdateOrganisationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Nouveau nom"
          },
          "logoUrl": {
            "type": "string",
            "example": "https://minio.bedones.local/logos/logo.png"
          }
        }
      },
      "UploadResponseDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://minio.bedones.local/logos/abc123.png"
          }
        },
        "required": [
          "url"
        ]
      },
      "ConnectPagesDto": {
        "type": "object",
        "properties": {
          "organisationId": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "redirectUri": {
            "type": "string"
          }
        },
        "required": [
          "organisationId",
          "code",
          "redirectUri"
        ]
      },
      "FAQRuleResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "question",
          "answer"
        ]
      },
      "PageSettingsResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "isConfigured": {
            "type": "boolean"
          },
          "undesiredCommentsAction": {
            "type": "string"
          },
          "spamAction": {
            "type": "string"
          },
          "customInstructions": {
            "type": "string"
          },
          "faqRules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FAQRuleResponseDto"
            }
          }
        },
        "required": [
          "id",
          "isConfigured",
          "undesiredCommentsAction",
          "spamAction",
          "faqRules"
        ]
      },
      "SocialAccountResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "FACEBOOK",
              "INSTAGRAM",
              "WHATSAPP",
              "TIKTOK"
            ]
          },
          "providerAccountId": {
            "type": "string"
          },
          "pageName": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "profilePictureUrl": {
            "type": "string"
          },
          "settings": {
            "$ref": "#/components/schemas/PageSettingsResponseDto"
          }
        },
        "required": [
          "id",
          "provider",
          "providerAccountId"
        ]
      },
      "UnreadCountDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "count": {
            "type": "number"
          }
        },
        "required": [
          "provider",
          "count"
        ]
      },
      "CommentResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "postId": {
            "type": "string"
          },
          "parentId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "fromId": {
            "type": "string"
          },
          "fromName": {
            "type": "string"
          },
          "fromAvatar": {
            "type": "string"
          },
          "createdTime": {
            "format": "date-time",
            "type": "string"
          },
          "isRead": {
            "type": "boolean"
          },
          "isPageReply": {
            "type": "boolean"
          },
          "status": {
