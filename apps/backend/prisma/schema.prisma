generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum AuthType {
  PASSWORD
  FACEBOOK
  INSTAGRAM
}

enum SocialProvider {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  TIKTOK
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum UserStatus {
  PENDING
  VERIFIED
}

enum MemberStatus {
  ACTIVE
  INVITED
}

enum CommentAction {
  NONE
  HIDE
  DELETE
  REPLY
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

// ─── Models ───

model User {
  id             String     @id @default(uuid())
  email          String?    @unique
  phone          String?    @unique
  name           String
  avatar         String?
  passwordHash   String?
  authType       AuthType
  providerUserId String?
  status         UserStatus @default(VERIFIED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  memberships              OrganisationMember[]
  sessions                 Session[]
  notificationPreference   NotificationPreference?
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganisationMember[]
  socialAccounts SocialAccount[]
}

model OrganisationMember {
  id             String       @id @default(uuid())
  userId         String
  organisationId String
  role           OrgRole      @default(MEMBER)
  status         MemberStatus @default(INVITED)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organisationId])
}

model SocialAccount {
  id                String         @id @default(uuid())
  organisationId    String
  organisation      Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  provider          SocialProvider
  providerAccountId String
  pageName          String?
  username          String?
  profilePictureUrl String?
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  scopes            String[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  settings      PageSettings?
  posts         Post[]
  conversations Conversation[]

  @@unique([provider, providerAccountId])
}

model PageSettings {
  id                       String    @id @default(uuid())
  socialAccountId          String    @unique
  socialAccount            SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  isConfigured             Boolean   @default(false)
  undesiredCommentsAction  String    @default("hide")
  spamAction               String    @default("delete")
  customInstructions       String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  faqRules FAQRule[]
}

model FAQRule {
  id             String       @id @default(uuid())
  pageSettingsId String
  pageSettings   PageSettings @relation(fields: [pageSettingsId], references: [id], onDelete: Cascade)
  question       String
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([pageSettingsId])
}

model Post {
  id              String        @id // Facebook Post ID or Instagram Media ID
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  message         String?
  imageUrl        String?
  permalinkUrl    String?
  comments        Comment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([socialAccountId])
}

model Comment {
  id            String        @id // Facebook/Instagram Comment ID
  postId        String
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId      String?
  message       String
  fromId        String
  fromName      String
  fromAvatar    String?
  createdTime   DateTime
  isRead        Boolean       @default(false)
  isPageReply   Boolean       @default(false)
  status        CommentStatus @default(VISIBLE)
  action        CommentAction @default(NONE)
  actionReason  String?
  replyMessage  String?
  permalinkUrl  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([postId])
  @@index([fromId])
  @@index([createdTime])
}

// ─── Messaging (Messenger, Instagram DM) ───

model Conversation {
  id                String         @id @default(uuid())
  socialAccountId   String
  socialAccount     SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  platformThreadId  String?        // Platform-specific thread/conversation ID
  participantId     String         // Platform user ID of the other party
  participantName   String
  participantAvatar String?
  lastMessageText   String?
  lastMessageAt     DateTime?
  unreadCount       Int            @default(0)
  messages          DirectMessage[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([socialAccountId, participantId])
  @@index([socialAccountId])
  @@index([lastMessageAt])
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  platformMsgId  String?      @unique // Platform-specific message ID
  message        String
  senderId       String
  senderName     String
  isFromPage     Boolean      @default(false)
  mediaUrl       String?
  mediaType      String?      // text, image, video, audio, file, sticker
  fileName       String?      // Original file name for file attachments
  fileSize       Int?         // File size in bytes
  replyToId      String?      // ID of the message being replied to
  replyTo        DirectMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DirectMessage[] @relation("MessageReplies")
  reactions      Json?        // Array of { senderId, emoji } reactions on this message
  createdTime    DateTime
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([createdTime])
}

// ─── Notification Preferences ───

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // WhatsApp notifications
  waNewMessage     Boolean @default(true)
  waNewComment     Boolean @default(false)
  waTicketAssigned Boolean @default(true)
  waTicketUrgent   Boolean @default(true)
  waAgentAlert     Boolean @default(true)
  waDailySummary   Boolean @default(false)

  // Email notifications (features & marketing)
  emailNewFeatures  Boolean @default(true)
  emailNewOffers    Boolean @default(true)
  emailTutorials    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
}
