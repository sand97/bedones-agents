generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum AuthType {
  PASSWORD
  FACEBOOK
  INSTAGRAM
}

enum SocialProvider {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  TIKTOK
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum CommentAction {
  NONE
  HIDE
  DELETE
  REPLY
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

// ─── Models ───

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  avatar         String?
  passwordHash   String?
  authType       AuthType
  providerUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships OrganisationMember[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganisationMember[]
  socialAccounts SocialAccount[]
}

model OrganisationMember {
  id             String       @id @default(uuid())
  userId         String
  organisationId String
  role           OrgRole      @default(OWNER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organisationId])
}

model SocialAccount {
  id                String         @id @default(uuid())
  organisationId    String
  organisation      Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  provider          SocialProvider
  providerAccountId String
  pageName          String?
  username          String?
  profilePictureUrl String?
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  scopes            String[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  settings PageSettings?
  posts    Post[]

  @@unique([provider, providerAccountId])
}

model PageSettings {
  id                       String    @id @default(uuid())
  socialAccountId          String    @unique
  socialAccount            SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  isConfigured             Boolean   @default(false)
  undesiredCommentsAction  String    @default("hide")
  spamAction               String    @default("delete")
  customInstructions       String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  faqRules FAQRule[]
}

model FAQRule {
  id             String       @id @default(uuid())
  pageSettingsId String
  pageSettings   PageSettings @relation(fields: [pageSettingsId], references: [id], onDelete: Cascade)
  question       String
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([pageSettingsId])
}

model Post {
  id              String        @id // Facebook Post ID or Instagram Media ID
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  message         String?
  imageUrl        String?
  permalinkUrl    String?
  comments        Comment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([socialAccountId])
}

model Comment {
  id            String        @id // Facebook/Instagram Comment ID
  postId        String
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId      String?
  message       String
  fromId        String
  fromName      String
  fromAvatar    String?
  createdTime   DateTime
  isRead        Boolean       @default(false)
  isPageReply   Boolean       @default(false)
  status        CommentStatus @default(VISIBLE)
  action        CommentAction @default(NONE)
  actionReason  String?
  replyMessage  String?
  permalinkUrl  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([postId])
  @@index([fromId])
  @@index([createdTime])
}
