generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum AuthType {
  PASSWORD
  FACEBOOK
  INSTAGRAM
  WHATSAPP
}

enum SocialProvider {
  FACEBOOK
  FACEBOOK_CATALOG
  INSTAGRAM
  WHATSAPP
  TIKTOK
}

// Granular outbound capabilities that can be disabled independently on a
// SocialAccount (e.g. lose messaging permission but keep comment moderation).
enum SocialFeature {
  COMMENT
  MESSAGE
}

enum MessageHistorySyncStatus {
  PENDING // not started yet
  RUNNING // backfill jobs in flight (or, for WhatsApp, awaiting Coexistence history webhooks)
  COMPLETED // backfill finished
  FAILED // backfill failed (see historySyncError)
  UNSUPPORTED // provider does not expose history for this account
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum UserStatus {
  PENDING
  VERIFIED
}

enum MemberStatus {
  ACTIVE
  INVITED
}

enum CommentAction {
  NONE
  HIDE
  DELETE
  REPLY
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum AgentStatus {
  DRAFT
  CONFIGURING
  READY
  ACTIVE
  PAUSED
}

enum AiActivationMode {
  OFF
  ALL
  CONTACTS
  LABELS
  EXCLUDE_LABELS
}

enum AiConversationOverride {
  FORCE_ON
  FORCE_OFF
}

enum CatalogAnalysisStatus {
  PENDING
  ANALYZING
  INDEXING
  COMPLETED
  FAILED
}

// Lifecycle of a "WhatsApp catalog → Commerce Manager" migration job.
enum CatalogMigrationStatus {
  QUEUED // waiting in the Bull queue for its turn (single extraction at a time)
  EXTRACTING // the connector is pulling the public catalogue from WhatsApp
  IMPORTING // pushing the extracted products into the Meta catalogue
  COMPLETED
  FAILED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum PromotionDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// Reward granted by a promotion. Mirrors LoyaltyRewardType so promotions can
// reward free products / store credit / a percentage, like loyalty bonuses.
enum PromotionRewardType {
  PRODUCTS
  CREDIT
  PERCENT
}

enum CreditMediaType {
  TEXT
  AUDIO
  IMAGE
}

// ─── Souscription & Paiement ───
// Forfait actif d'une organisation. Dérivé (mis en cache) depuis la souscription
// active : voir Subscription. FREE est le défaut tant qu'aucune souscription
// payante n'est active.
enum OrgPlan {
  FREE
  PRO
  BUSINESS
}

// Prestataire de paiement. Seul STRIPE est réellement intégré pour l'instant ;
// NOTCHPAY (Mobile Money) est prévu et déjà modélisé pour la suite.
enum PaymentProvider {
  STRIPE
  NOTCHPAY
}

// Statut d'une souscription récurrente (calé sur les statuts Stripe).
enum SubscriptionStatus {
  INCOMPLETE // session de checkout créée, paiement initial pas encore confirmé
  ACTIVE // abonnement actif et payé pour la période en cours
  PAST_DUE // échec de renouvellement, en attente de régularisation
  CANCELED // annulé (ne se renouvellera plus) — peut rester actif jusqu'à la fin de période
  EXPIRED // période terminée sans renouvellement
}

// Statut d'un paiement (souscription récurrente OU achat ponctuel de crédits).
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Nature d'un paiement : renouvellement/souscription récurrente, ou achat
// ponctuel de crédits supplémentaires (par paliers de 1000).
enum PaymentKind {
  SUBSCRIPTION
  CREDIT_PURCHASE
}

enum NotificationType {
  COMMENT_TO_READ
  COMMENT_AI_SUGGESTION
  COMMENT_DAILY_SUMMARY
  MESSAGE_TO_READ
  MESSAGE_AI_SUGGESTION
  MESSAGE_TICKET_CREATED
  // Deprecated: ticket "closed" notifications are replaced by per-status
  // notifications (see TicketStatusNotification). Kept in the enum to avoid a
  // destructive migration; no longer emitted or surfaced in the UI.
  MESSAGE_TICKET_CLOSED
  MESSAGE_DAILY_SUMMARY
}

// ─── Models ───

model User {
  id               String     @id @default(uuid())
  email            String?    @unique
  // Full phone number in E.164 format (e.g. "+237657888690"). Kept as the
  // unique key used for lookups across modules (members, invitations, OTP).
  phone            String?    @unique
  // Split components for display/formatting. `phoneCountryCode` is the dial
  // code with leading "+" (e.g. "+237"); `phoneLocal` is the local part
  // without the dial code (e.g. "657888690").
  phoneCountryCode String?
  phoneLocal       String?
  name             String
  avatar           String?
  passwordHash     String?
  authType         AuthType
  providerUserId   String?
  status           UserStatus @default(VERIFIED)
  // BCP-47 short tag ("fr", "en") used for outbound messages (e.g. WhatsApp
  // template language) and as the i18n hint until the user changes it.
  locale           String     @default("fr")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  memberships               OrganisationMember[]
  sessions                  Session[]
  notificationPreferences   NotificationPreference[]
  ticketStatusNotifications TicketStatusNotification[]
  whatsappOptInWindows      WhatsAppOptInWindow[]
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Organisation {
  id               String   @id @default(uuid())
  name             String
  logoUrl          String?
  // IANA timezone (e.g. "Africa/Douala", "Europe/Paris") used by the hourly
  // opt-in cron to detect when local 08:00 hits for this org. Set at creation
  // from the browser's Intl.DateTimeFormat().resolvedOptions().timeZone.
  timezone         String   @default("Africa/Douala")
  // Forfait actif (cache dénormalisé de la souscription active). Source de
  // vérité = la Subscription liée ; ce champ est mis à jour par les webhooks
  // Stripe pour un accès rapide (quota crédits, gates de features) sans jointure.
  plan             OrgPlan  @default(FREE)
  // Solde de crédits supplémentaires achetés ponctuellement (achat par palier de
  // 1000). S'ajoute au quota mensuel de base du forfait. Incrémenté à chaque
  // achat de crédits confirmé (webhook checkout.session.completed, mode payment).
  purchasedCredits Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members              OrganisationMember[]
  socialAccounts       SocialAccount[]
  catalogs             Catalog[]
  agents               Agent[]
  tickets              Ticket[]
  promotions           Promotion[]
  ticketStatuses       TicketStatus[]
  creditOperations     CreditOperation[]
  whatsappOptInWindows WhatsAppOptInWindow[]
  catalogMigrations    CatalogMigration[]
  subscription         Subscription?
  payments             Payment[]
}

model OrganisationMember {
  id             String       @id @default(uuid())
  userId         String
  organisationId String
  role           OrgRole      @default(MEMBER)
  status         MemberStatus @default(INVITED)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organisationId])
}

model SocialAccount {
  id                String         @id @default(uuid())
  organisationId    String
  organisation      Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  provider          SocialProvider
  providerAccountId String
  wabaId            String? // WhatsApp Business Account ID (for WHATSAPP provider)
  pageName          String?
  pageAbout         String?
  username          String?
  profilePictureUrl String?
  metadata          Json? // Provider-specific public profile details (e.g. WhatsApp Business profile)
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  scopes            String[]

  // ─── Account health / circuit breaker ───
  // Set to true once the account accumulates too many consecutive outbound
  // errors (or loses required permissions). When disabled we keep processing
  // INCOMING webhooks but stop all OUTBOUND calls (send/get/post). Re-enabled
  // only by a successful (re)connect through the OAuth callback.
  disabled          Boolean         @default(false)
  disabledReason    String?
  disabledAt        DateTime?
  // Count of consecutive outbound failures; reset to 0 on any success.
  consecutiveErrors Int             @default(0)
  // Features turned off granularly (e.g. TikTok messaging when the user is no
  // longer a business account) without disabling the whole account.
  featureDisabled   SocialFeature[]

  // ─── User-initiated soft disconnect ───
  // Set when the user explicitly disconnects the page/number from the app. The
  // row (and its history) is kept so it can be reconnected later, but the
  // account is hidden from active lists and outbound calls are stopped. Cleared
  // on a successful (re)connect through the OAuth/embedded-signup callback.
  disconnectedAt DateTime?

  // ─── Message history sync (14-day backfill on connect) ───
  // Tracks the initial backfill of the last 14 days of conversations/messages
  // that runs once when an account is connected. WhatsApp delivers its history
  // through Coexistence webhooks (no pull API), so for WHATSAPP this only
  // reflects whether the history webhook(s) have been received.
  historySyncStatus MessageHistorySyncStatus @default(PENDING)
  historySyncedAt   DateTime?
  historySyncError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings                  PageSettings?
  posts                     Post[]
  conversations             Conversation[]
  catalogs                  CatalogSocialAccount[]
  agentLink                 AgentSocialAccount?
  labels                    Label[]
  notificationPreferences   NotificationPreference[]
  ticketStatusNotifications TicketStatusNotification[]
  errorLogs                 SocialAccountErrorLog[]
  tickets                   Ticket[]

  loyaltyContacts                 LoyaltyContact[]
  loyaltyBonuses                  LoyaltyBonus[]
  loyaltyCampaigns                LoyaltyCampaign[]
  contactCommunicationPreferences ContactCommunicationPreference[]
  contactConsentEvents            ContactConsentEvent[]

  @@unique([provider, providerAccountId])
}

model Label {
  id              String        @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  name            String
  color           String        @default("#1677ff")
  order           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conversationLabels ConversationLabel[]

  @@index([socialAccountId])
}

model ConversationLabel {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  labelId        String
  label          Label        @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, labelId])
  @@index([conversationId])
  @@index([labelId])
}

// ─── Catalog & Products ───

model Catalog {
  id             String                @id @default(uuid())
  organisationId String
  organisation   Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name           String
  providerId     String? // External catalog ID (e.g. Facebook catalog ID)
  vertical       String? // Meta catalog vertical (e.g. "commerce"); only "commerce" supports WhatsApp products
  description    String? // AI-generated description of catalog contents
  analysisStatus CatalogAnalysisStatus @default(PENDING)
  productCount   Int                   @default(0)
  indexedCount   Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  products            Product[]
  socialAccounts      CatalogSocialAccount[]
  pageSettings        PageSettings[]
  promotions          Promotion[]
  productContexts     ProductContext[]
  collectionContexts  CollectionContext[]
  productPostLinks    ProductPostLink[]
  collectionPostLinks CollectionPostLink[]
  migrations          CatalogMigration[]
  imageTemplates      ImageTemplate[]

  @@index([organisationId])
}

// ─── Image Studio Templates ───
// Habillages réutilisables (cadres / overlays marketing) créés dans le Studio
// images. Par défaut le studio affiche des templates statiques ; dès qu'un user
// en modifie un, il est persisté ici (sourceKey = id du template statique
// d'origine, null pour un template créé de zéro). `definition` contient les
// éléments (texte, formes, zones, champs dynamiques) en JSON.
model ImageTemplate {
  id             String   @id @default(uuid())
  organisationId String
  catalogId      String
  catalog        Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  name           String
  format         String   @default("1:1")
  accent         String?
  definition     Json
  sourceKey      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([catalogId, sourceKey])
  @@index([organisationId])
  @@index([catalogId])
}

// ─── Product / Collection AI Context ───
// Products and collections live in Meta (Facebook Catalog), not in our DB. We
// store the user-curated AI context keyed by (catalogId, providerProductId) /
// (catalogId, providerCollectionId). The `content` field is plain text/markdown
// authored or refined by the AI from the user's natural-language prompt.

model ProductContext {
  id                String   @id @default(uuid())
  catalogId         String
  catalog           Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  providerProductId String // Meta product ID
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([catalogId, providerProductId])
  @@index([catalogId])
  @@index([catalogId, content])
}

model CollectionContext {
  id                   String   @id @default(uuid())
  catalogId            String
  catalog              Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  providerCollectionId String // Meta product set ID
  content              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([catalogId, providerCollectionId])
  @@index([catalogId])
  @@index([catalogId, content])
}

// Posts are stored locally (model Post) keyed by their provider ID (FB Post ID
// or IG Media ID). Link rows tie a Meta product/collection to a stored post.

model ProductPostLink {
  id                String   @id @default(uuid())
  catalogId         String
  catalog           Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  providerProductId String
  postId            String
  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@unique([catalogId, providerProductId, postId])
  @@index([catalogId, providerProductId])
  @@index([postId])
}

model CollectionPostLink {
  id                   String   @id @default(uuid())
  catalogId            String
  catalog              Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  providerCollectionId String
  postId               String
  post                 Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@unique([catalogId, providerCollectionId, postId])
  @@index([catalogId, providerCollectionId])
  @@index([postId])
}

model Product {
  id                  String   @id @default(uuid())
  catalogId           String
  catalog             Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  providerProductId   String? // External product ID
  name                String
  description         String?
  imageUrl            String?
  additionalImageUrls String[] @default([])
  price               Float?
  currency            String?  @default("XAF")
  category            String?
  status              String   @default("published") // published, draft, archived
  needsIndexing       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  promotionProducts       PromotionProduct[]
  promotionRewardProducts PromotionRewardProduct[]
  loyaltyTriggerLinks     LoyaltyBonusTriggerProduct[]
  loyaltyRewardLinks      LoyaltyBonusRewardProduct[]

  @@unique([catalogId, providerProductId])
  @@index([catalogId])
}

model CatalogSocialAccount {
  id              String        @id @default(uuid())
  catalogId       String
  catalog         Catalog       @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([catalogId, socialAccountId])
  @@index([catalogId])
  @@index([socialAccountId])
}

// One "import the products of a WhatsApp number into a Commerce Manager
// catalogue" request. Processed one-at-a-time through the `catalog-migration`
// Bull queue; progress is streamed to the browser over websockets.
model CatalogMigration {
  id                    String                 @id @default(uuid())
  organisationId        String
  organisation          Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  catalogId             String
  catalog               Catalog                @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  // Source WhatsApp number whose public catalogue is imported (digits only, no '+').
  sourcePhone           String
  // Optional link to the connected SocialAccount the number belongs to.
  sourceSocialAccountId String?
  status                CatalogMigrationStatus @default(QUEUED)
  totalProducts         Int                    @default(0)
  importedProducts      Int                    @default(0)
  failedProducts        Int                    @default(0)
  jobId                 String?
  error                 String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([organisationId])
  @@index([catalogId])
  @@index([status])
}

// ─── Agent ───

model Agent {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name           String?
  status         AgentStatus  @default(DRAFT)
  score          Int          @default(0)
  context        String? // AI-generated business context (markdown)
  liveModelTier  String       @default("flash") // live-agent model tier: flash | pro | ultra
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  socialAccounts   AgentSocialAccount[]
  messages         AgentMessage[]
  tickets          Ticket[]
  creditOperations CreditOperation[]

  @@index([organisationId])
}

model AgentSocialAccount {
  id                         String           @id @default(uuid())
  agentId                    String
  agent                      Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  socialAccountId            String           @unique // A social account can only be in ONE agent
  socialAccount              SocialAccount    @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  aiActivationMode           AiActivationMode @default(OFF)
  aiActivationLabels         String[] // Label IDs for LABELS / EXCLUDE_LABELS modes (legacy)
  aiActivationContacts       String[] // Phone numbers (WhatsApp) or profile names (IG/Messenger) — "by contacts" scope, mainly for testing
  // ─── Activation scopes (combinable, except aiActivateAll which is exclusive) ───
  aiActivateAll              Boolean          @default(false) // Respond on every conversation
  aiActivateAds              Boolean          @default(false) // Respond when the message originates from an ad (Meta referral / CTWA, TikTok)
  aiActivateNewConversations Boolean          @default(false) // Respond on conversations created after activation
  aiActivatedAt              DateTime? // Cutoff used by aiActivateNewConversations
  createdAt                  DateTime         @default(now())

  @@unique([agentId, socialAccountId])
  @@index([agentId])
}

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'agent' | 'system' | 'tool'
  content   String
  type      String   @default("text") // 'text' | 'mcq' | 'scq' | 'tool_status'
  metadata  Json? // Options for MCQ/SCQ, tool info, etc.
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([createdAt])
}

// ─── Tickets ───

model TicketStatus {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name           String
  color          String       @default("#000000")
  order          Int          @default(0)
  isDefault      Boolean      @default(false)

  tickets       Ticket[]
  notifications TicketStatusNotification[]

  @@index([organisationId])
}

model Ticket {
  id              String          @id @default(uuid())
  organisationId  String
  organisation    Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  agentId         String?
  agent           Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  statusId        String?
  status          TicketStatus?   @relation(fields: [statusId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  priority        TicketPriority  @default(MEDIUM)
  contactName     String?
  contactId       String? // Platform user ID
  provider        SocialProvider?
  conversationId  String? // Link to Conversation
  socialAccountId String? // Page/number (social account) the conversation belongs to
  socialAccount   SocialAccount?  @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  assignedTo      String? // OrganisationMember ID
  metadata        Json? // Extra data (order details, etc.)
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  activities TicketActivity[]

  @@index([organisationId])
  @@index([agentId])
  @@index([statusId])
  @@index([socialAccountId])
  @@index([createdAt])
}

model TicketActivity {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type       String // 'created' | 'status_change' | 'description_change'
  author     String // e.g. 'System', user name
  fromStatus String? // Previous status name (for status_change)
  toStatus   String? // New status name (for status_change)
  diff       Json? // { field, before, after } (for description_change)
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

// ─── Promotions ───

model Promotion {
  id             String                @id @default(uuid())
  organisationId String
  organisation   Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  // Catalog the promotion targets. Nullable for legacy org-wide promotions
  // created before promotions became catalog-scoped.
  catalogId      String?
  catalog        Catalog?              @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  name           String
  description    String?
  discountType   PromotionDiscountType @default(PERCENTAGE)
  discountValue  Float                 @default(0)
  code           String? // Promo code
  startDate      DateTime?
  endDate        DateTime?
  status         PromotionStatus       @default(DRAFT)
  stackable      Boolean               @default(false)

  // Eligibility thresholds (stackable). The promo applies only when the order
  // meets every threshold that is set. Null = the threshold is not enforced.
  minOrderAmount Float? // minimum order amount (FCFA) to be eligible
  minItemCount   Int? // minimum number of articles in the order to be eligible

  // Reward (mirrors LoyaltyBonus). When rewardType is null the legacy
  // discountType/discountValue pair still describes the reduction.
  rewardType    PromotionRewardType?
  rewardCredit  Float?
  rewardPercent Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       PromotionProduct[]
  rewardProducts PromotionRewardProduct[]

  @@index([organisationId])
  @@index([catalogId])
  @@index([status])
}

model PromotionProduct {
  id          String    @id @default(uuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@index([promotionId])
  @@index([productId])
}

// Free products offered as a promotion reward (rewardType = PRODUCTS).
model PromotionRewardProduct {
  id          String    @id @default(uuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@index([promotionId])
  @@index([productId])
}

// ─── Page Settings & Comments ───

model PageSettings {
  id                      String        @id @default(uuid())
  socialAccountId         String        @unique
  socialAccount           SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  isConfigured            Boolean       @default(false)
  undesiredCommentsAction String        @default("hide")
  spamAction              String        @default("delete")
  customInstructions      String?
  catalogId               String?
  catalog                 Catalog?      @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  faqRules FAQRule[]

  @@index([catalogId])
}

model FAQRule {
  id             String       @id @default(uuid())
  pageSettingsId String
  pageSettings   PageSettings @relation(fields: [pageSettingsId], references: [id], onDelete: Cascade)
  question       String
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([pageSettingsId])
}

model Post {
  id              String                  @id // Facebook Post ID or Instagram Media ID
  socialAccountId String
  socialAccount   SocialAccount           @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  message         String?
  imageUrl        String?
  permalinkUrl    String?
  aiOverride      AiConversationOverride? // Per-post override: FORCE_OFF disables agent replies to this post's comments
  comments        Comment[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  productLinks    ProductPostLink[]
  collectionLinks CollectionPostLink[]

  @@index([socialAccountId])
}

model Comment {
  id           String        @id // Facebook/Instagram Comment ID
  postId       String
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId     String?
  message      String
  fromId       String
  fromName     String
  fromAvatar   String?
  createdTime  DateTime
  isRead       Boolean       @default(false)
  isPageReply  Boolean       @default(false)
  status       CommentStatus @default(VISIBLE)
  action       CommentAction @default(NONE)
  actionReason String?
  replyMessage String?
  permalinkUrl String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([postId])
  @@index([fromId])
  @@index([createdTime])
}

// ─── Messaging (Messenger, Instagram DM, WhatsApp) ───

model Conversation {
  id                       String                           @id @default(uuid())
  socialAccountId          String
  socialAccount            SocialAccount                    @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  platformThreadId         String? // Platform-specific thread/conversation ID
  participantId            String // Platform user ID of the other party
  participantName          String
  participantUsername      String? // Platform username/handle (e.g. TikTok @username)
  participantAvatar        String?
  contactNameSynced        Boolean                          @default(false) // participantName came from the WhatsApp Business address-book sync (smb_app_state_sync); authoritative, not overwritten by message profile names
  languageCode             String?
  languageSource           ContactLanguageSource            @default(UNKNOWN)
  languageConfidence       Float?
  languageDetectedAt       DateTime?
  lastMessageText          String?
  lastMessageAt            DateTime?
  unreadCount              Int                              @default(0)
  historySyncedAt          DateTime? // last time the 14-day message backfill ran for this thread
  aiOverride               AiConversationOverride? // Per-conversation override of agent activation rules
  fromAd                   Boolean                          @default(false) // Conversation started from an ad (Meta CTWA / referral, TikTok)
  adReferral               Json? // Raw ad/referral metadata captured from the webhook (source, ad id, ctwa_clid, ...)
  messages                 DirectMessage[]
  conversationLabels       ConversationLabel[]
  campaignContacts         LoyaltyCampaignContact[]
  communicationPreferences ContactCommunicationPreference[]
  consentEvents            ContactConsentEvent[]
  contactNotes             ContactNote[]
  createdAt                DateTime                         @default(now())
  updatedAt                DateTime                         @updatedAt

  @@unique([socialAccountId, participantId])
  @@index([socialAccountId])
  @@index([lastMessageAt])
}

model DirectMessage {
  id              String                  @id @default(uuid())
  conversationId  String
  conversation    Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  platformMsgId   String?                 @unique // Platform-specific message ID
  message         String
  senderId        String
  senderName      String
  isFromPage      Boolean                 @default(false)
  mediaUrl        String?
  mediaType       String? // text, image, video, audio, file, sticker
  fileName        String? // Original file name for file attachments
  fileSize        Int? // File size in bytes
  replyToId       String? // ID of the message being replied to
  replyTo         DirectMessage?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         DirectMessage[]         @relation("MessageReplies")
  reactions       Json? // Array of { senderId, emoji } reactions on this message
  metadata        Json? // Interactive payload metadata: catalog products, order items, header/footer, etc.
  deliveryStatus  String? // WhatsApp delivery: 'sent' | 'delivered' | 'read'
  createdTime     DateTime
  isRead          Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  campaignContact LoyaltyCampaignContact?

  @@index([conversationId])
  @@index([createdTime])
}

// ─── Contact Notes (per-conversation customer memory) ───

/// Free-form notes the AI agent (or an operator) saves about the customer of a
/// conversation — delivery address, phone to call, clothing sizes, preferences…
/// Scoped to the conversation; the agent reads them back when re-engaging.
model ContactNote {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// The agent that recorded the note (informational; no FK so deletes are loose).
  agentId        String?
  /// Optional bucket, e.g. "delivery_address", "phone", "size", "preference".
  category       String?
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
}

// ─── Credit Operations ───

model CreditOperation {
  id             String          @id @default(uuid())
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  agentId        String?
  agent          Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversationId String?
  commentId      String?
  mediaType      CreditMediaType
  cost           Float
  createdAt      DateTime        @default(now())

  @@index([organisationId])
  @@index([organisationId, createdAt])
  @@index([createdAt])
}

// ─── Souscription récurrente (Stripe) ───
// Une organisation a au plus UNE souscription. En mode Stripe c'est un vrai
// abonnement récurrent (mode: subscription) qui se renouvelle automatiquement.
// L'achat ponctuel de crédits supplémentaires ne passe PAS par ici (voir
// Payment.kind = CREDIT_PURCHASE) : c'est un paiement one-shot, pas un abonnement.
model Subscription {
  id             String             @id @default(uuid())
  organisationId String             @unique
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  plan           OrgPlan
  status         SubscriptionStatus @default(INCOMPLETE)
  provider       PaymentProvider    @default(STRIPE)
  // Cadence de facturation choisie (1, 6 ou 12 mois). Le prix récurrent applique
  // la remise de durée correspondante ; l'abonnement Stripe se renouvelle tous
  // les `billingMonths` mois.
  billingMonths  Int                @default(1)
  // Crédits de base inclus chaque mois par le forfait (free=200, pro=1000,
  // business=3000). Dénormalisé pour le calcul du quota.
  monthlyCredits Int

  // Références Stripe (aucun price ID codé en dur : tout est créé dynamiquement).
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Période de facturation courante (renseignée par les webhooks Stripe).
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  // True quand l'utilisateur a demandé l'annulation : l'abonnement reste actif
  // jusqu'à currentPeriodEnd puis bascule en FREE.
  cancelAtPeriodEnd  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]

  @@index([stripeCustomerId])
}

// ─── Paiement / Transaction ───
// Enregistre aussi bien un paiement de souscription récurrente (kind =
// SUBSCRIPTION) qu'un achat ponctuel de crédits (kind = CREDIT_PURCHASE).
model Payment {
  id               String          @id @default(uuid())
  organisationId   String
  organisation     Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  kind             PaymentKind
  provider         PaymentProvider @default(STRIPE)
  status           PaymentStatus   @default(PENDING)
  amount           Float
  currency         String          @default("USD")
  // Pour kind = CREDIT_PURCHASE : nombre de crédits achetés (multiple de 1000).
  creditsPurchased Int?
  description      String?

  // Références Stripe pour la réconciliation et l'idempotence des webhooks.
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  stripeInvoiceId         String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
  @@index([subscriptionId])
  @@index([stripePaymentIntentId])
}

// ─── Notification Preferences ───
// Absence of a row = enabled (default). A row is only persisted when the user
// explicitly opts out (or re-enables after opting out). This keeps defaults
// evolvable without backfilling and makes bulk toggles cheap.
model NotificationPreference {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount    @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  type            NotificationType
  enabled         Boolean          @default(true)
  // For ticket notifications: restrict to these product collections (Meta
  // product_set ids). Empty = all collections (no filter).
  collectionIds   String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, socialAccountId, type])
  @@index([userId])
  @@index([socialAccountId])
}

// One row per (member, social account, ticket status). When a ticket on that
// account moves INTO the status, the subscribed members are notified. Unlike
// MESSAGE_TICKET_CREATED (default-on), these are opt-in: no row — or a disabled
// one — means no notification. `collectionIds` restricts the notification to
// these product collections (Meta product_set ids); empty = all collections.
model TicketStatusNotification {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  ticketStatusId  String
  ticketStatus    TicketStatus  @relation(fields: [ticketStatusId], references: [id], onDelete: Cascade)
  enabled         Boolean       @default(true)
  collectionIds   String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, socialAccountId, ticketStatusId])
  @@index([userId])
  @@index([socialAccountId])
  @@index([ticketStatusId])
}

// ─── WhatsApp Opt-In Window ───
// One row per (member, org). The template asks the member to opt in for
// notifications about a specific organisation, so a member who's part of
// several orgs has separate windows. All sends go through the Bedones CORE
// WhatsApp number (env CORE_WHATSAPP_NUMBER_ID), but the consent is per-org.
// The window refreshes to now+24h whenever the member replies — the most
// recent template sent to them (lastTemplateSentAt) tells us which org their
// reply belongs to, since Quick Reply payloads on Meta templates are static.
model WhatsAppOptInWindow {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisationId     String
  organisation       Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  expiresAt          DateTime
  lastInboundAt      DateTime?
  lastTemplateSentAt DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([userId, organisationId])
  @@index([expiresAt])
  @@index([userId])
}

// ─── Loyalty ───

enum LoyaltyTargetType {
  SPEND
  ORDER_COUNT
  PRODUCTS
}

enum LoyaltyRewardType {
  PRODUCTS
  CREDIT
  PERCENT
}

enum LoyaltyBonusStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum LoyaltyCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
  CANCELLED
  FAILED
}

enum LoyaltyCampaignFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum CampaignOrigin {
  LOYALTY
  GENERAL
}

enum CampaignAudienceType {
  RECENT_CONTACTS
  PRODUCT_INTEREST
  TICKET_STATUS
}

enum CampaignContactDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
}

enum ContactLanguageSource {
  UNKNOWN
  AI
  MANUAL
  IMPORT
  META
}

enum CommunicationChannel {
  WHATSAPP
}

enum CommunicationPurpose {
  MARKETING
  UTILITY
  LOYALTY
}

enum CommunicationPreferenceStatus {
  OPTED_IN
  OPTED_OUT
}

model LoyaltyContact {
  id              String        @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  totalSpent      Float         @default(0)
  orderCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([socialAccountId, phone])
  @@index([socialAccountId])
}

model LoyaltyBonus {
  id              String             @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount      @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          LoyaltyBonusStatus @default(DRAFT)
  stackable       Boolean            @default(false)

  // Targets (cumulable). Keep optional fields for each criterion.
  targetSpend         Float?
  targetOrderCount    Int?
  targetProductsCount Int? // number of distinct trigger products required

  // Reward
  rewardType    LoyaltyRewardType
  rewardCredit  Float?
  rewardPercent Float?

  startDate DateTime?
  endDate   DateTime?

  triggerProducts LoyaltyBonusTriggerProduct[]
  rewardProducts  LoyaltyBonusRewardProduct[]
  campaigns       LoyaltyCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([socialAccountId])
  @@index([status])
}

model LoyaltyBonusTriggerProduct {
  id        String       @id @default(uuid())
  bonusId   String
  bonus     LoyaltyBonus @relation(fields: [bonusId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bonusId, productId])
  @@index([bonusId])
  @@index([productId])
}

model LoyaltyBonusRewardProduct {
  id        String       @id @default(uuid())
  bonusId   String
  bonus     LoyaltyBonus @relation(fields: [bonusId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bonusId, productId])
  @@index([bonusId])
  @@index([productId])
}

model LoyaltyCampaign {
  id              String         @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  bonusId         String?
  bonus           LoyaltyBonus?  @relation(fields: [bonusId], references: [id], onDelete: SetNull)
  origin          CampaignOrigin @default(LOYALTY)

  // Meta WhatsApp template reference (templates are NOT persisted in our DB —
  // they live on Meta and we only keep the identifiers needed to send).
  metaTemplateId       String?
  metaTemplateName     String?
  metaTemplateLanguage String?

  name           String
  status         LoyaltyCampaignStatus    @default(SCHEDULED)
  frequency      LoyaltyCampaignFrequency @default(ONCE)
  marketingTopic String                   @default("general")

  // Segment criteria captured as JSON to remain flexible across bonus target types
  segmentCriteria     Json?
  audienceType        CampaignAudienceType?
  audienceCriteria    Json?
  audienceLimit       Int?
  templateAssignments Json?
  variableValues      Json?

  startDate DateTime?
  endDate   DateTime?

  // Counters (delivered / read / replied)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  repliedCount   Int @default(0)

  contacts      LoyaltyCampaignContact[]
  consentEvents ContactConsentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([socialAccountId])
  @@index([bonusId])
  @@index([origin])
  @@index([status])
}

model LoyaltyCampaignContact {
  id              String          @id @default(uuid())
  campaignId      String
  campaign        LoyaltyCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  conversationId  String
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  directMessageId String?         @unique
  directMessage   DirectMessage?  @relation(fields: [directMessageId], references: [id], onDelete: SetNull)

  contactPhone     String
  contactName      String
  languageCode     String?
  templateId       String?
  templateName     String?
  templateLanguage String?
  platformMsgId    String?                       @unique
  status           CampaignContactDeliveryStatus @default(PENDING)
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  repliedAt        DateTime?
  failedAt         DateTime?
  error            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, conversationId])
  @@index([campaignId])
  @@index([campaignId, status])
  @@index([conversationId])
  @@index([platformMsgId])
}

model ContactCommunicationPreference {
  id              String                        @id @default(uuid())
  conversationId  String
  conversation    Conversation                  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount                 @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  channel         CommunicationChannel          @default(WHATSAPP)
  purpose         CommunicationPurpose
  topic           String                        @default("general")
  status          CommunicationPreferenceStatus
  source          String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  @@unique([conversationId, channel, purpose, topic])
  @@index([socialAccountId])
  @@index([socialAccountId, purpose, topic, status])
}

model ContactConsentEvent {
  id              String               @id @default(uuid())
  conversationId  String?
  conversation    Conversation?        @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  socialAccountId String
  socialAccount   SocialAccount        @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        LoyaltyCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  channel         CommunicationChannel @default(WHATSAPP)
  purpose         CommunicationPurpose
  topic           String               @default("general")
  action          String
  source          String?
  rawText         String?
  metadata        Json?
  createdAt       DateTime             @default(now())

  @@index([conversationId])
  @@index([socialAccountId])
  @@index([campaignId])
  @@index([purpose, topic])
}

// Append-only log of outbound provider API failures. Powers the consecutive
// error counter / circuit breaker and feeds the human-friendly error bank.
model SocialAccountErrorLog {
  id              String         @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  provider        SocialProvider
  // Outbound capability that failed, when applicable (helps target a granular
  // disable instead of the whole account).
  feature         SocialFeature?
  // Service method that triggered the call (e.g. "sendMessage", "findProducts").
  operation       String?
  // Logical resource the user must reconnect to fix this (e.g. "page",
  // "catalog", "tiktok", "instagram"). Passed to the LLM explanation prompt.
  resource        String?
  // Provider/HTTP error code (e.g. "190", "OAuthException", "400").
  errorCode       String?
  // Raw provider error payload / stack for debugging and "show details".
  errorTrace      String
  createdAt       DateTime       @default(now())

  @@index([socialAccountId, createdAt])
}

// Cache of human-friendly, multilingual explanations generated by an LLM for a
// given class of provider error. Reused across accounts so we only pay the LLM
// once per distinct error signature.
model ProviderErrorMessage {
  id        String         @id @default(uuid())
  // Stable hash of provider + errorCode + resource used to dedupe/lookups.
  signature String         @unique
  provider  SocialProvider
  errorCode String?
  resource  String?
  // Localized explanations, shape: { "en": string, "fr": string, ... }.
  messages  Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─── MCP (Model Context Protocol) ───
// OAuth 2.1 layer that lets external AI assistants (Claude Connectors,
// ChatGPT Apps SDK) drive Bedones as MCP tools. Bridged to the existing
// User / Session / Organisation model. See src/mcp/.

model McpOAuthClient {
  id           String   @id @default(uuid())
  clientId     String   @unique
  clientSecret String? // null for public (PKCE) clients
  clientName   String?
  redirectUris String[]
  scope        String?
  createdAt    DateTime @default(now())

  @@index([clientId])
}

model McpAuthCode {
  id                  String   @id @default(uuid())
  code                String   @unique
  clientId            String
  userId              String
  organisationId      String
  redirectUri         String
  scope               String?
  codeChallenge       String?
  codeChallengeMethod String?
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  @@index([code])
}

model McpAccessToken {
  id               String    @id @default(uuid()) // also the JWT `jti`
  refreshTokenHash String?   @unique
  clientId         String
  userId           String
  organisationId   String
  scope            String?
  expiresAt        DateTime
  refreshExpiresAt DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([organisationId])
}
