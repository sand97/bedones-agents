# Server
PORT=3001
NODE_ENV=development

# WhatsApp session (whatsapp-web.js LocalAuth)
WHATSAPP_SESSION_PATH=./data/sessions
# false = a visible Chrome opens with the QR; true = headless (use GET /whatsapp/qr)
WHATSAPP_PUPPETEER_HEADLESS=false
# false = the client starts on POST /whatsapp/start; true = starts on boot
WHATSAPP_AUTOSTART=false
# Optional: path to a Chromium/Chrome binary (defaults to puppeteer's bundled one / CHROME_BIN)
PUPPETEER_EXECUTABLE_PATH=

# Optional instance targeting: when set, callers must send a matching
# `x-bedones-target-instance` header (bedones-agents' WHATSAPP_CONNECTOR_INSTANCE_ID).
CONNECTOR_INSTANCE_ID=
