{
  "name": "whatsapp-connector",
  "version": "0.0.1",
  "private": true,
  "description": "WhatsApp connector — minimal wppconnect service to scrape public catalogues (inspired by the standalone bedones-whatsapp connector)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@wppconnect/wa-js": "^3.22.1",
    "axios": "^1.7.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.1.0",
    "qrcode-terminal": "0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "whatsapp-web.js": "1.34.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.7.2"
  }
}
